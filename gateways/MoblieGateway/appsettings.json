{
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "attendance": {
        "ClusterId": "attendances",
        "Match": {
          "Path": "/attendances/{**catch-all}",
          "Methods": [
            "GET",
            "POST",
            "PUT",
            "DELETE"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "api/attendances/{**catch-all}"
          }
        ]
      },
      "student": {
        "ClusterId": "students",
        "Match": {
          "Path": "/students/{**catch-all}",
          "Methods": [
            "GET",
            "POST",
            "PUT",
            "DELETE"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "api/students/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "attendances": {
        "Destinations": {
          "attendancesApi": {
            "Swaggers": [
              {
                "PrefixPath": "/swagger/attendances",
                "Paths": [
                  "/swagger/v1/swagger.json"
                ]
              }
            ]
          }
        }
      },
      "students": {
        "Destinations": {
          "studentsApi": {
            "Swaggers": [
              {
                "PrefixPath": "/swagger/students",
                "Paths": [
                  "/swagger/v1/swagger.json"
                ]
              }
            ]
          }
        }
      }
    }
  }
}
